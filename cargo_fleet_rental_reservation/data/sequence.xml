<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================
         SÉQUENCE : Référence automatique des réservations CRM
         Format : RES/YYYY/NNNNN  (ex: RES/2024/00042)
    ================================================================ -->

    <record id="seq_crm_lead_rental_reference" model="ir.sequence">
        <field name="name">Référence réservation location CRM</field>
        <field name="code">crm.lead.rental.reference</field>
        <field name="prefix">RES/%(year)s/</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="use_date_range">False</field>
        <field name="company_id" eval="False"/>
    </record>

</odoo>