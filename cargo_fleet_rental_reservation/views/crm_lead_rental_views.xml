<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="crm_lead_rental_form_view" model="ir.ui.view">
        <field name="name">crm.lead.rental.form.clean</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">

            <!-- ===================== STATUSBAR ===================== -->
            
            <!-- ===================== BOUTON ===================== -->
            <xpath expr="//header" position="inside">
                <button name="action_cancel_reservation"
                        string="Annuler"
                        type="object"
                        class="btn-danger"
                        invisible="type != 'opportunity' or reservation_status in ['converti','annule','initial']"
                        confirm="Annuler cette réservation ?"/>
            </xpath>

            <!-- ===================== HEADER CLEAN ===================== -->
<xpath expr="//field[@name='user_id']/../.." position="after">
    <div class="row">
        <div class="col-6">
            <div class="o_row">
                <label for="rental_reference" string="Référence" class="o_form_label"/>
                <field name="rental_reference"
                       string="Référence"/>
            </div>
            <div class="o_row">
                <label for="lead_source" string="Source" class="o_form_label"/>
                <field name="lead_source"
                       string="Source"
                       placeholder="Ex: Site web, Appel..."/>
            </div>
        </div>
    </div>
</xpath>

            <!-- ===================== CONTRAT ===================== -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <group invisible="not fleet_contract_id">
                    <group>
                        <field name="fleet_contract_name" readonly="1"/>
                    </group>
                    <group>
                        <field name="fleet_contract_state" readonly="1"/>
                    </group>
                </group>
            </xpath>

            <!-- ===================== MASQUAGE ===================== -->
            <xpath expr="//field[@name='expected_revenue']" position="replace"/>
            <xpath expr="//label[@for='expected_revenue']" position="replace"/>

            <xpath expr="//field[@name='probability']" position="replace"/>
            <xpath expr="//label[@for='probability']" position="replace"/>

            <xpath expr="//h2[.//div[@id='probability']]" position="replace"/>

            <xpath expr="//field[@name='date_deadline']" position="replace"/>
            <xpath expr="//label[@for='date_deadline']" position="replace"/>

            <xpath expr="//field[@name='tag_ids']" position="replace"/>
            <xpath expr="//field[@name='priority']" position="replace"/>

            <!-- ===================== NOTEBOOK ===================== -->
           <xpath expr="//notebook" position="inside">
    <page string="Location"
          name="rental_reservation"
          invisible="type != 'opportunity'">

        <group col="2">

            <!-- ===== COLONNE GAUCHE ===== -->
            <group>

                <!-- Références -->
            
                <!-- Véhicule -->
                <separator string="Véhicule"/>
                <field name="vehicle_category_id"
                       options="{'no_create': True}"
                       readonly="reservation_status == 'converti'"/>
                <field name="contract_type"
                       readonly="reservation_status == 'converti'"/>

                <!-- Période -->
                <separator string="Période de location"/>
                <field name="rent_start_datetime"
                       readonly="reservation_status == 'converti'"/>
                <field name="rent_end_datetime"
                       readonly="reservation_status == 'converti'"/>

                <field name="number_of_days" readonly="1"/>
                <field name="number_of_months"
                       readonly="1"
                       invisible="contract_type not in ['medium','long']"/>

            </group>

            <!-- ===== COLONNE DROITE ===== -->
            <group>

                <!-- Tarification -->
                <separator string="Tarification"/>
                <field name="rental_tariff_id"
                       options="{'no_create': True}"
                       readonly="reservation_status == 'converti'"/>
                <field name="estimated_daily_rate"
                       readonly="reservation_status == 'converti'"/>
                <field name="discount_percent"
                       readonly="reservation_status == 'converti'"/>
                <field name="rental_vat_percent"
                       readonly="reservation_status == 'converti'"/>

                <!-- Totaux -->
                <separator string="Totaux"/>
                <field name="estimated_total_ht" readonly="1"/>
                <field name="estimated_total_ttc" readonly="1"/>

            </group>

        </group>

        <!-- ===== NOTES ===== -->
        <group string="Notes internes">
            <field name="rental_notes"
                   nolabel="1"
                   placeholder="Informations complémentaires..."
                   readonly="reservation_status == 'converti'"/>
        </group>

    </page>
</xpath>
        </field>
    </record>

</odoo>