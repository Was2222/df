                <field name="date_end"/>
                <field name="document_year"/>

                <separator/>

                <filter name="filter_doc_not_paid"
                        string="Non payés"
                        domain="[('state', '=', 'not_paid')]"/>

                <filter name="filter_doc_purchase_created"
                        string="BC créés"
                        domain="[('state', '=', 'purchase_created')]"/>

                <filter name="filter_doc_billed"
                        string="Facturés"
                        domain="[('state', '=', 'billed')]"/>

                <filter name="filter_doc_paid"
                        string="Payés"
                        domain="[('state', '=', 'paid')]"/>

                <filter name="filter_doc_to_pay"
                        string="À payer"
                        domain="[('state', '=', 'not_paid')]"/>

                <filter name="filter_doc_current_year"
                        string="Année courante"
                        domain="[('document_year', '=', context_today().year)]"/>

                <filter name="filter_doc_avoirise"
                        string="Avoirisés"
                        domain="[('state', '=', 'avoirise')]"/>

                <separator/>

                <filter name="group_by_document_type"
                        string="Type"
                        context="{'group_by': 'document_type'}"/>

                <filter name="group_by_immat"
                        string="Immatriculation"
                        context="{'group_by': 'license_plate'}"/>

                <filter name="group_by_numero_w"
                        string="Numéro W"
                        context="{'group_by': 'numero_w'}"/>

                <filter name="group_by_supplier"
                        string="Fournisseur"
                        context="{'group_by': 'supplier_id'}"/>

                <filter name="group_by_state"
                        string="Statut"
                        context="{'group_by': 'state'}"/>

                <filter name="group_by_vehicle_display"
                        string="Immatriculation / Numéro W"
                        context="{'group_by': 'vehicle_display'}"/>
            </search>
        </field>
    </record>

