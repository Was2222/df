<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_fleet_vehicle_document_tree" model="ir.ui.view">
        <field name="name">fleet.vehicle.document.tree</field>
        <field name="model">fleet.vehicle.document</field>
        <field name="arch" type="xml">
            <list string="Documents administratifs" create="0" editable="bottom">
                <field name="name"/>
                <field name="license_plate" string="Immatriculation"/>
                <field name="numero_w" string="Numéro W"/>
                <field name="type_acquisition" string="Type d'acquisition"/>
                <field name="model_name" string="Modèle"/>
                <field name="brand_name" string="Marque"/>
                <field name="category_id" string="Catégorie"/>
                <field name="vin_sn" string="N° de châssis"/>
                <field name="document_type"/>
                <field name="supplier_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="amount" string="Montant TTC" readonly="1"/>

                <field name="state"
                       widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-danger="state == 'not_paid'"
                       decoration-warning="state == 'billed'"
                       decoration-info="state == 'purchase_created'"
                       decoration-primary="state == 'avoirise'"
                       decoration-muted="state == 'expired'"/>

                <button name="action_create_purchase_order"
                        type="object"
                        string="Créer BC"
                        class="btn-primary"
                        invisible="purchase_order_id or document_type not in ('carte_grise', 'permis_circulation', 'assurance', 'vignette', 'visite', 'immatriculation', 'jawaz', 'carburant', 'carte_verte')"/>

                <button name="action_view_purchase_order"
                        type="object"
                        string="Voir BC"
                        invisible="not purchase_order_id"/>

                <button name="action_view_source_purchase_order"
                        type="object"
                        string="Voir contrat source"
                        invisible="not source_purchase_order_id"/>

                <button name="action_view_vendor_bill"
                        type="object"
                        string="Voir facture"
                        invisible="not bill_id"/>

            </list>
        </field>
    </record>

    <record id="view_fleet_vehicle_document_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.document.form</field>
        <field name="model">fleet.vehicle.document</field>
        <field name="arch" type="xml">
            <form string="Document administratif">
                <header>

                    <button name="action_create_purchase_order"
                            type="object"
                            string="Créer BC"
                            class="btn-primary"
                            invisible="purchase_order_id or document_type not in ('carte_grise', 'permis_circulation', 'assurance', 'vignette', 'visite', 'immatriculation', 'jawaz', 'carburant', 'carte_verte')"/>

                    <button name="action_view_purchase_order"
                            type="object"
                            string="Voir BC"
                            invisible="not purchase_order_id"/>

                    <button name="action_view_source_purchase_order"
                            type="object"
                            string="Voir contrat source"
                            invisible="not source_purchase_order_id"/>

                    <button name="action_view_vendor_bill"
                            type="object"
                            string="Voir facture fournisseur"
                            invisible="not bill_id"/>

                    <field name="state"
                           widget="statusbar"
                           invisible="not has_status"
                           statusbar_visible="not_paid,purchase_created,billed,paid,avoirise,expired"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="license_plate" string="Immatriculation"/>
                            <field name="numero_w" string="Numéro W" readonly="1"/>
                            <field name="type_acquisition" string="Type d'acquisition" readonly="1"/>
                            <field name="model_name" string="Modèle" readonly="1"/>
                            <field name="brand_name" string="Marque" readonly="1"/>
                            <field name="category_id" string="Catégorie" readonly="1"/>
                            <field name="vin_sn" string="N° de châssis" readonly="1"/>
                            <field name="document_type"/>
                            <field name="supplier_id"/>
                        </group>
                        <group string="Informations assurance"
                            invisible="document_type != 'assurance'">
                            <group>
                                <field name="assurance_attestation_number"/>
                                <field name="assurance_policy_number"/>
                            </group>
                        </group>

                        <group string="Informations vignette"
                            invisible="document_type != 'vignette'">
                            <group>
                                <field name="vignette_number"/>
                            </group>
                        </group>

                        <group string="Informations visite technique"
                            invisible="document_type != 'visite'">
                            <group>
                                <field name="visite_number"/>
                                <field name="visite_type"/>
                                <field name="visite_center"/>
                            </group>
                        </group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                            <field name="amount" string="Montant TTC" readonly="1"/>
                            <field name="insurance_type" invisible="document_type != 'assurance'"/>
                            <field name="source_purchase_order_id" readonly="1"/>
                            <field name="purchase_order_id" readonly="1"/>
                            <field name="bill_id" readonly="1"/>
                            <field name="invoice_number" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Commentaire">
                            <field name="notes"/>
                        </page>

                        <page string="Pièce jointe">
                            <group>
                                <field name="attachment" filename="attachment_filename"/>
                                <field name="attachment_filename" invisible="1"/>
                            </group>
                        </page>

                        <page string="Détails mensuels"
                              invisible="document_type not in ('assurance', 'vignette', 'visite')">
                            <field name="monthly_detail_ids" readonly="1">
                                <list string="Détails mensuels">
                                    <field name="month_date"/>
                                    <field name="label"/>
                                    <field name="amount"/>
                                </list>
                            </field>

                            <group class="oe_subtotal_footer oe_right">
                                <field name="monthly_total" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fleet_vehicle_document_search" model="ir.ui.view">
        <field name="name">fleet.vehicle.document.search</field>
        <field name="model">fleet.vehicle.document</field>
        <field name="arch" type="xml">
            <search string="Documents administratifs">
                <field name="name"/>
                <field name="license_plate" string="Immatriculation"/>
                <field name="numero_w" string="Numéro W"/>
                <field name="type_acquisition" string="Type d'acquisition"/>
                <field name="model_name" string="Modèle"/>
                <field name="brand_name" string="Marque"/>
                <field name="category_id" string="Catégorie"/>
                <field name="vin_sn" string="N° de châssis"/>
                <field name="document_type"/>
                <field name="supplier_id"/>
                <field name="state"/>
                <field name="document_year"/>

                <separator/>

                <filter name="filter_not_paid"
                        string="Non payés"
                        domain="[('state', '=', 'not_paid')]"/>

                <filter name="filter_to_pay"
                        string="À payer"
                        domain="[('state', '=', 'not_paid')]"/>

                <filter name="filter_current_year"
                        string="Année courante"
                        domain="[('document_year', '=', context_today().year)]"/>

                <filter name="group_by_document_type"
                        string="Type"
                        context="{'group_by': 'document_type'}"/>

                <filter name="group_by_immat"
                        string="Immatriculation"
                        context="{'group_by': 'license_plate'}"/>

                <filter name="group_by_numero_w"
                        string="Numéro W"
                        context="{'group_by': 'numero_w'}"/>

                <filter name="group_by_supplier"
                        string="Fournisseur"
                        context="{'group_by': 'supplier_id'}"/>
            </search>
        </field>
    </record>

