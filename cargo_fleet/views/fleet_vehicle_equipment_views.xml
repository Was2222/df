<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- TYPES D'EQUIPEMENT -->

    <record id="view_fleet_vehicle_equipment_type_list" model="ir.ui.view">
        <field name="name">fleet.vehicle.equipment.type.list</field>
        <field name="model">fleet.vehicle.equipment.type</field>
        <field name="arch" type="xml">
            <list string="Types d'équipement">
                <field name="name"/>
                <field name="product_tmpl_id"/>
                <field name="equipment_count"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_vehicle_equipment_type_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.equipment.type.form</field>
        <field name="model">fleet.vehicle.equipment.type</field>
        <field name="arch" type="xml">
            <form string="Type d'équipement">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="product_tmpl_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_vehicle_equipment_type" model="ir.actions.act_window">
        <field name="name">Types d'équipement</field>
        <field name="res_model">fleet.vehicle.equipment.type</field>
        <field name="view_mode">list,pivot,graph,form</field>
    </record>

    <!-- EQUIPEMENTS -->

    <record id="view_fleet_vehicle_equipment_list" model="ir.ui.view">
        <field name="name">fleet.vehicle.equipment.list</field>
        <field name="model">fleet.vehicle.equipment</field>
        <field name="arch" type="xml">
            <list string="Equipements véhicule">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="equipment_type_id"/>
                <field name="serial_number"/>
                <field name="purchase_date"/>
                <field name="amount"/>
                <field name="state"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_vehicle_equipment_form" model="ir.ui.view">
        <field name="name">fleet.vehicle.equipment.form</field>
        <field name="model">fleet.vehicle.equipment</field>
        <field name="arch" type="xml">
            <form string="Equipement véhicule">
                <sheet>
                    <group col="4">
                        <group>
                            <field name="name"/>
                            <field name="vehicle_id"/>
                            <field name="equipment_type_id"/>
                            <field name="serial_number"/>
                        </group>
                        <group>
                            <field name="purchase_date"/>
                            <field name="amount"/>
                            <field name="state"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                    </group>

                    <group>
                        <field name="notes"/>
                    </group>

                    <group>
                        <field name="product_tmpl_id" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_vehicle_equipment" model="ir.actions.act_window">
        <field name="name">Equipements véhicule</field>
        <field name="res_model">fleet.vehicle.equipment</field>
        <field name="view_mode">list,pivot,graph,form</field>
    </record>

    <!-- MENUS -->

    <menuitem id="menu_fleet_vehicle_equipment_root"
              name="Equipements"
              parent="fleet.menu_root"
              sequence="70"/>

    <menuitem id="menu_fleet_vehicle_equipment_type"
              name="Types d'équipement"
              parent="menu_fleet_vehicle_equipment_root"
              action="action_fleet_vehicle_equipment_type"
              sequence="1"/>

    <menuitem id="menu_fleet_vehicle_equipment"
              name="Equipements véhicule"
              parent="menu_fleet_vehicle_equipment_root"
              action="action_fleet_vehicle_equipment"
              sequence="2"/>

</odoo>