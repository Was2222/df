              sequence="38"/>

    <menuitem id="menu_purchase_immatriculation_orders"
              name="Achat frais immatriculation"
              parent="purchase.menu_procurement_management"
              action="action_purchase_immatriculation_orders"
              sequence="39"/>

    <menuitem id="menu_purchase_penalite_orders"
              name="Achat pénalités"
              parent="purchase.menu_procurement_management"
              action="action_purchase_penalite_orders"
              sequence="40"/>
    <menuitem id="menu_purchase_permis_circulation_orders"
            name="Achat permis de circulation"
            parent="purchase.menu_procurement_management"
            action="action_purchase_permis_circulation_orders"
            sequence="35"/>

    <menuitem id="menu_purchase_carte_grise_orders"
            name="Achat carte grise"
            parent="purchase.menu_procurement_management"
            action="action_purchase_carte_grise_orders"
            sequence="36"/>

</odoo>