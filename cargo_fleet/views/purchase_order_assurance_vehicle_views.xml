<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_purchase_order_document_line_tree" model="ir.ui.view">
        <field name="name">purchase.order.document.line.tree</field>
        <field name="model">purchase.order.document.line</field>
        <field name="arch" type="xml">
            <list string="Documents achat véhicule">
                <field name="purchase_order_id"/>
                <field name="service_code"/>
                <field name="document_id"/>
                <field name="supplier_reference"/>
                <field name="vehicle_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="insurance_type"/>
                <field name="amount"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_order_document_line_form" model="ir.ui.view">
        <field name="name">purchase.order.document.line.form</field>
        <field name="model">purchase.order.document.line</field>
        <field name="arch" type="xml">
            <form string="Document achat véhicule">
                <sheet>
                    <group>
                        <field name="purchase_order_id"/>
                        <field name="service_code"/>
                        <field name="document_id"/>
                        <field name="supplier_reference" readonly="1"/>
                        <field name="vehicle_id" readonly="1"/>
                        <field name="date_start"/>
                        <field name="date_end"/>
                        <field name="insurance_type"/>
                        <field name="amount"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>