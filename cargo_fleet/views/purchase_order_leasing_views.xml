    <record id="action_leasing_current_month" model="ir.actions.act_window">
        <field name="name">Leasing à payer</field>
        <field name="res_model">leasing.echeance</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="domain">[
            '&amp;',
            ('state', 'in', ['draft', 'partial', 'late']),
            ('date_echeance', '&lt;=', (context_today() + relativedelta(months=1, day=1, days=-1)).strftime('%Y-%m-%d'))
        ]</field>
        <field name="search_view_id" ref="view_leasing_echeance_search_month_custom"/>
        <field name="context">{'search_default_filter_unpaid': 1, 'search_default_group_by_vehicle': 1}</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_leasing_echeance_tree_month_custom')}),
            (0, 0, {'view_mode': 'form', 'view_id': ref('view_leasing_echeance_form')})
        ]"/>
    </record>

    <record id="purchase_order_form_hide_buttons_leasing" model="ir.ui.view">
        <field name="name">purchase.order.form.hide.buttons.leasing</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority" eval="999"/>
        <field name="arch" type="xml">

            <xpath expr="//header/button[@id='bid_confirm']" position="attributes">
                <attribute name="invisible">state != 'sent' or vehicle_purchase_type == 'leasing_contract'</attribute>
            </xpath>

            <xpath expr="//header/button[@id='draft_confirm']" position="attributes">
                <attribute name="invisible">state != 'draft' or vehicle_purchase_type == 'leasing_contract'</attribute>
            </xpath>

            <xpath expr="//header/button[@name='action_rfq_send'][1]" position="attributes">
                <attribute name="invisible">state != 'draft' or vehicle_purchase_type == 'leasing_contract'</attribute>
            </xpath>

            <xpath expr="//header/button[@name='action_rfq_send'][2]" position="attributes">
                <attribute name="invisible">state != 'sent' or vehicle_purchase_type == 'leasing_contract'</attribute>
            </xpath>

        </field>
    </record>

