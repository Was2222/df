    <field name="model">leasing.echeance</field>
    <field name="arch" type="xml">
        <search string="Recherche échéancier leasing">

            <!-- Champs de recherche -->
            <field name="purchase_order_id" string="Contrat leasing"/>
            <field name="license_plate" string="Immatriculation"/>
            <field name="numero_w" string="Numéro W"/>
            <field name="model_name" string="Modèle"/>
            <field name="brand_name" string="Marque"/>
            <field name="sequence" string="Séquence"/>
            <field name="date_echeance" string="Date échéance"/>
            <field name="date_prelevement_reel" string="Date prélèvement réel"/>
            <field name="payment_mode" string="Mode paiement"/>
            <field name="capital_amount" string="Capital"/>
            <field name="interest_amount" string="Intérêt"/>
            <field name="amount_ht" string="Montant HT"/>
            <field name="tax_ids" string="Taxes"/>
            <field name="tva_amount" string="Montant TVA"/>
            <field name="amount_total" string="Montant total"/>
            <field name="amount_penalite" string="Montant pénalité"/>
            <field name="amount_paid" string="Montant payé"/>
            <field name="amount_due" string="Montant restant"/>
            <field name="payment_date" string="Date paiement"/>
            <field name="state" string="Statut"/>

