            <!-- Filtres -->
            <filter name="filter_unpaid"
                    string="À payer"
                    domain="[('state', 'in', ['draft', 'partial', 'late'])]"/>

            <filter name="filter_purchase_order"
                    string="Avec contrat leasing"
                    domain="[('purchase_order_id', '!=', False)]"/>

            <filter name="filter_license_plate"
                    string="Avec immatriculation"
                    domain="[('license_plate', '!=', False)]"/>

            <filter name="filter_numero_w"
                    string="Avec numéro W"
                    domain="[('numero_w', '!=', False)]"/>

            <filter name="filter_model"
                    string="Avec modèle"
                    domain="[('model_name', '!=', False)]"/>

            <filter name="filter_brand"
                    string="Avec marque"
                    domain="[('brand_name', '!=', False)]"/>

            <filter name="filter_sequence"
                    string="Avec séquence"
                    domain="[('sequence', '!=', False)]"/>

            <filter name="filter_date_echeance"
                    string="Avec date échéance"
                    domain="[('date_echeance', '!=', False)]"/>

            <filter name="filter_date_prelevement_reel"
                    string="Avec date prélèvement réel"
                    domain="[('date_prelevement_reel', '!=', False)]"/>

            <filter name="filter_payment_mode"
                    string="Avec mode paiement"
                    domain="[('payment_mode', '!=', False)]"/>

            <filter name="filter_capital_amount"
                    string="Avec capital"
                    domain="[('capital_amount', '!=', 0)]"/>

            <filter name="filter_interest_amount"
                    string="Avec intérêt"
                    domain="[('interest_amount', '!=', 0)]"/>

            <filter name="filter_amount_ht"
                    string="Avec montant HT"
                    domain="[('amount_ht', '!=', 0)]"/>

            <filter name="filter_tax_ids"
                    string="Avec taxes"
                    domain="[('tax_ids', '!=', False)]"/>

            <filter name="filter_tva_amount"
                    string="Avec montant TVA"
                    domain="[('tva_amount', '!=', 0)]"/>

            <filter name="filter_amount_total"
                    string="Avec montant total"
                    domain="[('amount_total', '!=', 0)]"/>

            <filter name="filter_amount_penalite"
                    string="Avec pénalité"
                    domain="[('amount_penalite', '!=', 0)]"/>

            <filter name="filter_amount_paid"
                    string="Avec montant payé"
                    domain="[('amount_paid', '!=', 0)]"/>

            <filter name="filter_amount_due"
                    string="Avec montant restant"
                    domain="[('amount_due', '!=', 0)]"/>

            <filter name="filter_payment_date"
                    string="Avec date paiement"
                    domain="[('payment_date', '!=', False)]"/>

            <filter name="filter_state"
                    string="Avec statut"
                    domain="[('state', '!=', False)]"/>

            <separator/>

            <!-- Group By -->
            <filter name="group_by_contract"
                    string="Contrat"
                    context="{'group_by': 'purchase_order_id'}"/>

            <filter name="group_by_license_plate"
                    string="Immatriculation"
                    context="{'group_by': 'license_plate'}"/>

            <filter name="group_by_numero_w"
                    string="Numéro W"
                    context="{'group_by': 'numero_w'}"/>

            <filter name="group_by_model"
                    string="Modèle"
                    context="{'group_by': 'model_name'}"/>

            <filter name="group_by_brand"
                    string="Marque"
                    context="{'group_by': 'brand_name'}"/>

            <filter name="group_by_payment_mode"
                    string="Mode paiement"
                    context="{'group_by': 'payment_mode'}"/>

            <filter name="group_by_date_echeance"
                    string="Date échéance"
                    context="{'group_by': 'date_echeance'}"/>

            <filter name="group_by_payment_date"
                    string="Date paiement"
                    context="{'group_by': 'payment_date'}"/>

            <filter name="group_by_state"
                    string="Statut"
                    context="{'group_by': 'state'}"/>

        </search>
    </field>
</record>

