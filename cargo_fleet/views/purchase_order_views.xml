<record id="action_vehicle_purchase_contracts" model="ir.actions.act_window">
        <field name="name">Contrats d'achat</field>
        <field name="res_model">purchase.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('vehicle_purchase_type', '=', 'contract')]</field>
        <field name="context">{'default_vehicle_purchase_type': 'contract', 'create': False}</field>
        <field name="view_ids" eval="[
