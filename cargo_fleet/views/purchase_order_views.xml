    <record id="purchase_order_search_inherit_contrat_v2" model="ir.ui.view">
        <field name="name">purchase.order.search.inherit.contrat.v2</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.view_purchase_order_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <separator/>
                <filter name="group_by_origin_contrat"
                        string="Contrat"
                        context="{'group_by': 'origin'}"/>
            </xpath>
        </field>
    </record>

